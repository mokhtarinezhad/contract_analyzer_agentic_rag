# Copy this file to .env and fill in your secrets.
# Non-secret settings are in backend/config.py
#
# ── LLM API Keys ──────────────────────────────────────────────────────────────
# At least ONE of the two keys below is required.
# Add both to enable the full model selector (Anthropic + OpenAI models).
#
# Anthropic models: claude-sonnet-4-6, claude-opus-4-7, claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI models: gpt-4o, gpt-4o-mini, gpt-4-turbo
# Leave blank if you only want to use Anthropic models.
OPENAI_API_KEY=sk-...
